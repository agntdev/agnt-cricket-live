BOT_TOKEN=

# Live-update provider configuration
# Allowed values: cricbuzz, cricapi, sportradar, cricketdata, custom
# Default: cricbuzz (no API key required)
LIVE_UPDATE_PROVIDER=cricbuzz
LIVE_UPDATE_API_URL=
LIVE_UPDATE_API_KEY=

# Optional secondary provider for fallback when primary fails
SECONDARY_LIVE_UPDATE_PROVIDER=
SECONDARY_LIVE_UPDATE_API_URL=
SECONDARY_LIVE_UPDATE_API_KEY=
